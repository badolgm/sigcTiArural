[run]
source = api
branch = True
omit =
    */tests/*
    */migrations/*
    */__pycache__/*
    */conftest.py

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    def __repr__
    raise NotImplementedError

precision = 2
show_missing = True

[html]
directory = htmlcov
# Fase 1 (Consolidate Domain): simple coverage config for characterization tests of the existing
# hexagonal nucleus (api/logic/domain strategies, factories, services).
# The new tests (historico for all labs + multi-switch) brought domain coverage to ~100% for the 4 strategies.
# Use: pytest  (uses pytest.ini + this .coveragerc). Reports visible in verify_refactor.ps1 [5].
# Helps track Sec 7.8 progress without any prod code changes. Low-risk only.